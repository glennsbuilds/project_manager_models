{
  "name": "@melodysdad/pm-pipeline-cdk",
  "version": "1.0.0",
  "type": "module",
  "description": "Generated CDK constructs for project manager pipelines (Step Functions, Lambda, agents)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
