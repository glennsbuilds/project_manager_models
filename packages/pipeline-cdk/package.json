    "directory": "packages/pipeline-cdk"
  },
  "scripts": {
    "build": "tsc",
    "prepublish": "npm run build"
  },
  "keywords": [
    "project-manager",
    "cdk",
    "step-functions",
    "pipeline",
    "infrastructure"
  ],
  "peerDependencies": {
    "aws-cdk-lib": "^2.0.0",
    "constructs": "^10.0.0"
  }
